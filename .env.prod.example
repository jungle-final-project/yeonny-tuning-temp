POSTGRES_DB=buildgraph
POSTGRES_USER=buildgraph
POSTGRES_PASSWORD=replace-with-strong-postgres-password
RABBITMQ_DEFAULT_USER=buildgraph
RABBITMQ_DEFAULT_PASS=replace-with-strong-rabbitmq-password
BUILDGRAPH_AUTH_JWT_SECRET=replace-with-at-least-32-bytes-random-secret
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://d1a7gxvxxd385i.cloudfront.net/api/auth/google/callback
GOOGLE_OAUTH_WEB_CALLBACK_URL=https://d1a7gxvxxd385i.cloudfront.net/auth/callback

# CloudFront distribution domain used by the deployed web app.
BUILDGRAPH_CORS_ALLOWED_ORIGINS=https://d1a7gxvxxd385i.cloudfront.net
VITE_API_BASE_URL=

AGENT_RUNNER_MODE=deterministic
AGENT_LOG_STORAGE_ROOT=/data/agent-logs
AGENT_DEMO_ACTIVATION_TOKEN=
PART_MANUFACTURER_RELEASE_DEMO_FEED_ENABLED=false
DEMO_FREEZE_MUTATIONS=false

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
OPENAI_REASONING_EFFORT=medium
PC_AGENT_DIAGNOSIS_CHAT_MODEL=gpt-5.4-mini
PC_AGENT_DIAGNOSIS_CHAT_REASONING_EFFORT=low
PC_AGENT_DIAGNOSIS_CHAT_MAX_OUTPUT_TOKENS=750
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

RAG_VECTOR_ENABLED=true
RAG_VECTOR_REQUIREMENT_PARSE_ENABLED=true
RAG_VECTOR_BUILD_RECOMMEND_ENABLED=true
RAG_VECTOR_AS_ANALYZE_ENABLED=true
RAG_VECTOR_PUBLIC_SEARCH_ENABLED=true
RAG_EMBEDDING_BACKFILL_ON_STARTUP=false

AS_CHAT_DEFAULT_PROFILE=AS_CHAT_54_MINI_FAST
BUILD_CHAT_DEFAULT_PROFILE=BUILD_CHAT_54_MINI_FAST
BUILD_CHAT_CACHE_ENABLED=true
BUILD_CHAT_CACHE_TTL_SECONDS=600
BUILD_CHAT_CACHE_PREWARM_ENABLED=true
BUILD_CHAT_CACHE_PREWARM_TTL_SECONDS=3600
BUILD_CHAT_CACHE_PREWARM_REFRESH_DELAY_MS=2700000
BUILD_CHAT_SEMANTIC_CACHE_ENABLED=true
BUILD_CHAT_SEMANTIC_CACHE_THRESHOLD=0.94
BUILD_CHAT_SEMANTIC_CACHE_TTL_SECONDS=600
BUILD_CHAT_TIER_SNAPSHOT_ENABLED=true
BUILD_CHAT_TIER_SNAPSHOT_MIN_BUDGET_WON=2000000
BUILD_CHAT_TIER_SNAPSHOT_MAX_BUDGET_WON=13000000
BUILD_CHAT_TIER_SNAPSHOT_STEP_WON=1000000
BUILD_CHAT_TIER_SNAPSHOT_REFRESH_DELAY_MS=3600000
BUILD_CHAT_TIER_SNAPSHOT_TOLERANCE_PCT=15

RECOMMENDATION_RERANKER_ENABLED=false
RECOMMENDATION_RERANKER_SHADOW_ENABLED=true
RECOMMENDATION_RERANKER_ENDPOINT=http://xgb-reranker:8091/score
RECOMMENDATION_RERANKER_TIMEOUT_MS=1200
RECOMMENDATION_RERANKER_MODEL_PATH=/models/home-parts-active.json
RECOMMENDATION_TRAINING_WORKER_ENABLED=false
RECOMMENDATION_TRAINING_MIN_ROWS=50
RECOMMENDATION_TRAINING_POLL_SECONDS=5

NAVER_SEARCH_CLIENT_ID=
NAVER_SEARCH_CLIENT_SECRET=
NAVER_SEARCH_BASE_URL=https://openapi.naver.com

PART_PRICE_REFRESH_ENABLED=true
PART_PRICE_REFRESH_CRON="0 0 4 * * *"
PART_PRICE_REFRESH_ZONE=Asia/Seoul
PART_DANAWA_REFRESH_ENABLED=false
PART_DANAWA_REFRESH_CRON="0 30 4 * * *"
PART_DANAWA_REFRESH_ZONE=Asia/Seoul
PART_DANAWA_BASE_URL=https://search.danawa.com
PART_DANAWA_RATE_LIMIT_MS=3000
PART_DANAWA_TREND_REFRESH_ENABLED=false
PART_DANAWA_TREND_REFRESH_CRON="0 30 5 1 * *"
PART_DANAWA_TREND_REFRESH_ZONE=Asia/Seoul
PART_DANAWA_TREND_BASE_URL=https://prod.danawa.com
PART_DANAWA_TREND_SEARCH_BASE_URL=https://search.danawa.com
PART_DANAWA_TREND_RATE_LIMIT_MS=3000
PART_MANUFACTURER_RELEASE_INTAKE_ENABLED=false
PART_MANUFACTURER_RELEASE_INTAKE_CRON="0 0 6 * * *"
PART_MANUFACTURER_RELEASE_INTAKE_ZONE=Asia/Seoul
PART_MANUFACTURER_RELEASE_INTAKE_USER_AGENT=BuildGraphBot/0.1
SCHEDULING_POOL_SIZE=4
